    "from prophet import Prophet\n",
    "import pandas as pd\n",
    "\n",
    "# Create sample dataframe\n",
    "df = pd.read_csv(\"random.csv\")\n",
    "\n",
    "model = Prophet()\n",
    "model.fit(df)\n",
    "\n",
    "future = model.make_future_dataframe(periods=30)\n",
    "forecast = model.predict(future)\n",
    "\n",
    "model.plot(forecast)"
   ]
